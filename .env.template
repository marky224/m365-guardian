# ──────────────────────────────────────────────
# M365 Guardian — Environment Configuration
# Copy to .env and fill in your values.
#
# This shows the configuration surface. Every production feature is environment-gated:
# leave a section blank to disable it (the app runs locally with in-memory storage,
# console logging, and the Teams endpoint disabled). Provisioning the Azure side
# (managed identities, Graph permissions, the Exchange sidecar, the Teams app) is
# documented privately and available under license.
# ──────────────────────────────────────────────

# ── Secret management ──
# Leave KEY_VAULT_URL blank for local dev: secrets are read from this file. In production,
# set it to your Key Vault URL and the app's MANAGED IDENTITY (DefaultAzureCredential)
# fetches secrets at startup instead of reading them here. Microsoft Graph (app-only)
# authenticates via managed identity directly and needs no client secret in production.
# KEY_VAULT_URL=https://your-vault.vault.azure.net/

# ── Azure AD / Entra ID App Registration ──
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-app-client-id
AZURE_CLIENT_SECRET=your-app-client-secret

# ── Web sign-in via Workload Identity Federation (secretless, prod) ──
# Set AZURE_USE_WIF=true to authenticate the MSAL web sign-in client with a managed-identity
# assertion instead of AZURE_CLIENT_SECRET (which can then be left blank in prod). Requires a
# USER-ASSIGNED managed identity configured as a federated identity credential on the app reg.
# AZURE_USE_WIF=true
# AZURE_WIF_MANAGED_IDENTITY_CLIENT_ID=your-user-assigned-mi-client-id

# ── Exchange Online PowerShell sidecar (optional; real shared-mailbox / dist-group ops) ──
# Leave EXO_SIDECAR_URL blank to keep manage_shared_mailbox / manage_distribution_group
# honest-limited (they return not_implemented). When set, the app's MANAGED IDENTITY mints a
# token for EXO_SIDECAR_AUDIENCE and POSTs operations to the sidecar. Secretless — no function key.
# EXO_SIDECAR_URL=https://your-exo-sidecar.azurewebsites.net/api/ManageExchange
# EXO_SIDECAR_AUDIENCE=api://your-exo-sidecar          # the sidecar's app-reg App ID URI / client id
# EXO_SIDECAR_MANAGED_IDENTITY_CLIENT_ID=              # optional UAMI client id; blank = system-assigned

# ── LLM Configuration (via LiteLLM) ──
LLM_PROVIDER=xai                          # anthropic | azure_openai | openai | xai
XAI_API_KEY=your-xai-key
LLM_MODEL=grok-4-1-fast-reasoning         # default model
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.1                        # low temp for reliable tool calling

# ── Azure OpenAI (if LLM_PROVIDER=azure_openai) ──
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=https://your-instance.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=gpt-4o

# ── Azure Bot Service ──
# BOT_APP_TYPE drives Bot Framework auth: SingleTenant | MultiTenant | UserAssignedMSI.
# SingleTenant/MSI also require BOT_APP_TENANT_ID (defaults to AZURE_TENANT_ID if unset).
# Leave BOT_APP_ID blank to disable the Teams endpoint (web-only / local dev).
BOT_APP_ID=your-bot-app-id
BOT_APP_PASSWORD=your-bot-app-password
BOT_APP_TYPE=SingleTenant
# BOT_APP_TENANT_ID=your-bot-home-tenant-id

# ── Azure Cosmos DB (session + audit storage) ──
# COSMOS_KEY: set for local dev / the Cosmos emulator. Leave it BLANK in production to use
# managed identity (AAD RBAC) instead. With no COSMOS_ENDPOINT, storage is in-memory.
COSMOS_ENDPOINT=https://your-cosmos.documents.azure.com:443/
COSMOS_KEY=your-cosmos-key
COSMOS_DATABASE=m365guardian
COSMOS_SESSIONS_CONTAINER=sessions
COSMOS_AUDIT_CONTAINER=audit_logs

# ── Weekly Report Configuration ──
REPORT_TEAMS_TEAM_ID=your-team-id
REPORT_TEAMS_CHANNEL_ID=your-channel-id
REPORT_EMAIL_RECIPIENTS=admin@contoso.com,it-lead@contoso.com
REPORT_SENDER_UPN=m365guardian@contoso.com
REPORT_SCHEDULE_CRON=0 8 * * 1             # Every Monday at 8:00 AM UTC

# ── Web App ──
WEB_APP_PORT=8080
WEB_APP_BASE_URL=https://your-app.azurewebsites.net

# ── Logging & Telemetry ──
LOG_LEVEL=INFO
# Leave blank to disable telemetry (local dev = console logging only). When set, the app ships
# traces/metrics/logs to Application Insights via OpenTelemetry and instruments the aiohttp server.
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=https://...

# ── Security / MFA Enforcement ──
# Entra ID security group targeted by a Conditional Access 'require MFA' policy.
# enforce_mfa adds/removes users from this group. Leave blank to disable MFA enforcement.
MFA_REQUIRED_GROUP_ID=your-mfa-required-group-object-id

# ── Session / Auth ──
SESSION_SECRET=change-me-in-production
